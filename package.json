{
  "name": "grok-desktop",
  "productName": "Grok",
  "version": "1.0.0",
  "description": "Unofficial Grok desktop app with multi-tab support for Linux and Windows",
  "main": "src/main.js",
  "author": {
    "name": "Leila Schooley",
    "email": "leila@users.noreply.github.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/LeilaSchooley/grok-desktop",
  "desktopName": "grok-desktop",
  "repository": {
    "type": "git",
    "url": "https://github.com/LeilaSchooley/grok-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/LeilaSchooley/grok-desktop/issues"
  },
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --linux deb AppImage --win nsis portable --publish never",
    "dist:linux": "electron-builder --linux deb AppImage --publish never",
    "dist:deb": "electron-builder --linux deb --publish never",
    "dist:win": "electron-builder --win nsis portable --publish never"
  },
  "build": {
    "appId": "com.grok.desktop",
    "productName": "Grok",
    "copyright": "Copyright © 2026 Grok Desktop",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Network",
      "icon": "assets/icons",
      "syncDesktopName": true,
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "maintainer": "Leila Schooley <leila@users.noreply.github.com>",
      "desktop": {
        "entry": {
          "Name": "Grok",
          "Comment": "Grok AI desktop app",
          "Categories": "Network;Chat;",
          "StartupWMClass": "Grok"
        }
      },
      "synopsis": "Unofficial Grok desktop client"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.png",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Grok",
      "artifactName": "${productName}-${version}-setup-${os}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${os}-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12"
  }
}
